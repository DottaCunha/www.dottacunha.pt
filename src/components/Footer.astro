---
import type { Lang } from '../i18n/translations';
import { t, localizedPath } from '../i18n/utils';
import Logo from './Logo.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const currentYear = new Date().getFullYear();
---

<div class="bg-neutral text-neutral-content">
  <div class="container section flex flex-col gap-20 !pb-10">
    <footer class="footer md:footer-horizontal justify-items-stretch md:justify-between items-center">
      <aside>
        <div class="mb-3">
          <Logo size="lg" color="white" />
        </div>
        <span class="font-display font-semibold text-display-xs tracking-tight uppercase block">Dotta & Cunha, Lda</span>
        <p class="leading-relaxed mt-3 max-w-sm">
          {t('footer.description', lang)}
        </p>
      </aside>
      <nav>
        <a href={localizedPath('/contact', lang)} class="btn btn-outline w-full lg:width-auto">{t('footer.startConversation', lang)}</a>
      </nav>
    </footer>

    <footer class="footer md:footer-horizontal">
      <nav>
        <h4 class="footer-title text-info">{t('footer.navigation', lang)}</h4>
        <a class="link link-hover" href={localizedPath('/', lang)}>{t('nav.home', lang)}</a>
        <a class="link link-hover" href={localizedPath('/about', lang)}>{t('nav.about', lang)}</a>
        <a class="link link-hover" href={localizedPath('/projects', lang)}>{t('nav.projects', lang)}</a>
        <a class="link link-hover" href={localizedPath('/services', lang)}>{t('nav.services', lang)}</a>
        <a class="link link-hover" href={localizedPath('/contact', lang)}>{t('nav.contact', lang)}</a>
      </nav>
      <nav>
        <h4 class="footer-title text-info">{t('footer.services', lang)}</h4>
        <a class="link link-hover" href={localizedPath('/services', lang)}>{t('footer.development', lang)}</a>
        <a class="link link-hover" href={localizedPath('/services', lang)}>{t('footer.architecture', lang)}</a>
        <a class="link link-hover" href={localizedPath('/services', lang)}>{t('footer.projectManagement', lang)}</a>
        <a class="link link-hover" href={localizedPath('/services', lang)}>{t('footer.investmentAdvisory', lang)}</a>
      </nav>
      <nav>
        <h4 class="footer-title text-info">{t('footer.contact', lang)}</h4>
        <span class="">info@dottacunha.com</span>
        <span class="">+351 XXX XXX XXX</span>
        <span class="">Lisbon, Portugal</span>
      </nav>
      <nav>
        <h4 class="footer-title text-info">{t('footer.social', lang)}</h4>
        <a class="link link-hover" href="#">LinkedIn</a>
        <a class="link link-hover" href="#">Instagram</a>
      </nav>
    </footer>

    <footer class="footer md:footer-horizontal md:justify-between border-t border-dark-800 pt-8">
      <aside>
        <p class="text-xxs text-info">&copy; {currentYear} Dotta & Cunha. {t('footer.rights', lang)}</p>
      </aside>
      <nav class="flex gap-8">
        <a class="link link-hover text-xxs text-info" href="#">{t('footer.privacy', lang)}</a>
        <a class="link link-hover text-xxs text-info" href="#">{t('footer.terms', lang)}</a>
      </nav>
    </footer>
  </div>
</div>
