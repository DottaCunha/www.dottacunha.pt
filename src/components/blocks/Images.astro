---
import PublicPicture from "../PublicPicture.astro";

export interface Props {
  label?: string;
  heading?: string;
  images: string[];
  variant: "primary" | "secondary";
}

const { label, heading, images, variant = "primary" } = Astro.props;
---

{
  variant === "primary" && (
    <section class="px-6 md:px-8">
      <div class="container">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:h-[50vh]">
          {images.map((src: string, i: number) => (
            <div class="overflow-hidden aspect-[4/3] md:aspect-auto md:h-full">
              <PublicPicture
                src={src}
                alt={`Image ${i + 1}`}
                formats={['avif', 'webp']}
                widths={[400, 800, 1200, 1600]}
                sizes="(max-width: 768px) 100vw, (max-width: 1280px) 33vw, 415px"
                loading="lazy"
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
