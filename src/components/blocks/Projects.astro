---
import type { Lang } from "../../i18n/translations";
import { t, localizedPath } from "../../i18n/utils";
import {
  getFeaturedProjectsByLang,
  getProjectsByLang,
  getProjectSlug,
  getStatusLabel,
} from "../../lib/projects";

interface BaseProps {
  label: string;
  heading: string;
  variant: string;
}

interface FeaturedProps extends BaseProps {
  viewAllLabel: string;
  variant: "featured";
}

interface AllProps extends BaseProps {
  variant: "all";
}

export type Props = FeaturedProps | AllProps;

const { lang } = Astro.params as { lang: Lang };

const props = Astro.props;

const projects =
  props.variant === "featured"
    ? await getFeaturedProjectsByLang(lang)
    : await getProjectsByLang(lang);
---

{
  props.variant === "featured" && (
    <section class="section bg-base-200 text-base-content">
      <div class="container">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
          <div>
            <span class="section-label mb-3">{props.label}</span>
            <h2 class="section-heading">{props.heading}</h2>
          </div>
          <a
            href={localizedPath("/projects", lang)}
            class="text-link text-info hover:text-base-content flex items-center gap-2"
          >
            {props.viewAllLabel}
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M17 8l4 4m0 0l-4 4m4-4H3"
              />
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {projects.map((project) => {
            const d = project.data;
            const slug = getProjectSlug(project.id);
            const statusLabel = getStatusLabel(d.status, t, lang);
            return (
              <a href={localizedPath(`/projects/${slug}`, lang)} class="group">
                <div class="relative overflow-hidden aspect-[3/4] mb-5">
                  <img
                    src={d.image}
                    alt={d.title}
                    class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
                  <div class="absolute top-4 left-4">
                    <span class="badge bg-primary text-primary-content">
                      {statusLabel}
                    </span>
                  </div>
                </div>
                <div>
                  <h3 class="heading-card-sm group-hover:text-dark-600 transition-colors">
                    {d.title}
                  </h3>
                  <p class="text-body-xs mt-1">
                    {d.location} — {d.totalUnits} {t("projects.units", lang)}
                  </p>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )
}
{
  props.variant === "all" && (
    <section class="section bg-base-100 text-base-content">
      <div class="container">
        <div class="space-y-32">
          {projects.map((project, index) => {
            const d = project.data;
            const slug = getProjectSlug(project.id);
            const statusLabel = getStatusLabel(d.status, t, lang);
            return (
              <article
                class:list={[
                  "grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start",
                  index % 2 !== 0 ? "lg:[direction:rtl]" : "",
                ]}
              >
                <a
                  href={localizedPath(`/projects/${slug}`, lang)}
                  class="lg:col-span-7 relative overflow-hidden aspect-[4/3] block group"
                >
                  <img
                    src={d.image}
                    alt={d.title}
                    class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
                    loading="lazy"
                  />
                  <div class="absolute top-5 left-5">
                    <span
                      class:list={[
                        "badge",
                        d.status === "completed"
                          ? "bg-primary text-primary-content"
                          : d.status === "under_construction"
                            ? "bg-base-100 text-base-content"
                            : "bg-base-300 text-dark-600",
                      ]}
                    >
                      {statusLabel}
                    </span>
                  </div>
                </a>
                <div
                  class:list={[
                    "lg:col-span-5 py-4",
                    index % 2 !== 0 ? "lg:[direction:ltr]" : "",
                  ]}
                >
                  <div class="flex items-center gap-4 mb-5">
                    <span class="text-meta text-xxs">{d.type}</span>
                    <span class="text-dark-200">—</span>
                    <span class="text-footnote text-dark-300 font-light">
                      {d.year}
                    </span>
                  </div>
                  <a href={localizedPath(`/projects/${slug}`, lang)}>
                    <h2 class="font-display text-2xl md:text-3xl font-bold text-base-content tracking-tight uppercase mb-3 hover:text-dark-600 transition-colors">
                      {d.title}
                    </h2>
                  </a>
                  <p class="text-body-xs mb-6">{d.location}</p>
                  <p class="text-body mb-10">{d.description}</p>
                  <div class="grid grid-cols-3 gap-6 mb-10 border-t border-base-300 pt-8">
                    <div>
                      <div class="font-display text-xl font-bold text-base-content tracking-tight">
                        {d.totalUnits}
                      </div>
                      <div class="text-meta mt-1">
                        {t("projectDetail.totalUnits", lang)}
                      </div>
                    </div>
                    <div>
                      <div class="font-display text-xl font-bold text-base-content tracking-tight">
                        {d.area} m²
                      </div>
                      <div class="text-meta mt-1">
                        {t("projectsPage.area", lang)}
                      </div>
                    </div>
                    <div>
                      <div class="font-display text-xl font-bold text-base-content tracking-tight">
                        {d.year}
                      </div>
                      <div class="text-meta mt-1">
                        {t("projectsPage.year", lang)}
                      </div>
                    </div>
                  </div>
                  <a
                    href={localizedPath(`/projects/${slug}`, lang)}
                    class="btn btn-outline"
                  >
                    {t("projectsPage.inquire", lang)}
                    <svg
                      class="w-4 h-4 ml-2"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.5"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"
                      />
                    </svg>
                  </a>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )
}
