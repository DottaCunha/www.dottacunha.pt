---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en" data-theme="dottacunha">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Page Not Found | Dotta & Cunha</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen flex items-center justify-center bg-primary text-primary-content">
  <div class="text-center px-6">
    <span class="font-display text-[8rem] md:text-[12rem] font-extrabold leading-none tracking-tight opacity-20 block">404</span>
    <h1 class="font-display text-2xl md:text-4xl font-bold tracking-tight uppercase -mt-8 mb-4">Page Not Found</h1>
    <p class="text-body max-w-md mx-auto mb-10 opacity-80">The page you're looking for doesn't exist or has been moved.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/pt" class="btn btn-outline">Voltar ao Início</a>
      <a href="/en" class="btn btn-outline">Back to Home</a>
    </div>
  </div>
</body>
</html>
