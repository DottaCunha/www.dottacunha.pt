---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, localizedPath, getI18nPaths } from '../../i18n/utils';
import type { Lang } from '../../i18n/translations';
import { getProjectsByLang, getProjectSlug, getStatusLabel } from '../../lib/projects';
import { getCollection } from 'astro:content';

export function getStaticPaths() { return getI18nPaths(); }

const { lang } = Astro.params as { lang: Lang };
const projects = await getProjectsByLang(lang);

const allPages = await getCollection('pages');
const projectsPage = allPages.find(p => p.id === `${lang}/projects`);
const page = projectsPage!.data;
---

<BaseLayout title={t('nav.projects', lang)} lang={lang} darkHeader>
  {page.hero && (
  <section class="section relative min-h-[40vh] flex items-end overflow-hidden bg-primary text-primary-content">
    <div class="absolute inset-0">
      <img src={page.hero.image} alt={page.hero.title} class="w-full h-full object-cover opacity-30" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/40 to-primary/60"></div>
    </div>
    <div class="container relative z-10">
      <span class="section-label mb-4">{page.hero.label}</span>
      <h1 class="heading-hero text-5xl md:text-7xl lg:text-display">{page.hero.title}</h1>
    </div>
  </section>
  )}

  <section class="section bg-base-100 text-base-content">
    <div class="container">
      <div class="space-y-32">
        {projects.map((project, index) => {
          const d = project.data;
          const slug = getProjectSlug(project.id);
          const statusLabel = getStatusLabel(d.status, t, lang);
          return (
            <article class:list={[
              'grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start',
              index % 2 !== 0 ? 'lg:[direction:rtl]' : ''
            ]}>
              <a href={localizedPath(`/projects/${slug}`, lang)} class="lg:col-span-7 relative overflow-hidden aspect-[4/3] block group">
                <img src={d.image} alt={d.title} class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700" loading="lazy" />
                <div class="absolute top-5 left-5">
                  <span class:list={[
                    'badge',
                    d.status === 'completed' ? 'bg-primary text-primary-content' :
                    d.status === 'under_construction' ? 'bg-base-100 text-base-content' :
                    'bg-base-300 text-dark-600'
                  ]}>
                    {statusLabel}
                  </span>
                </div>
              </a>
              <div class:list={['lg:col-span-5 py-4', index % 2 !== 0 ? 'lg:[direction:ltr]' : '']}>
                <div class="flex items-center gap-4 mb-5">
                  <span class="text-meta text-xxs">{d.type}</span>
                  <span class="text-dark-200">—</span>
                  <span class="text-footnote text-dark-300 font-light">{d.year}</span>
                </div>
                <a href={localizedPath(`/projects/${slug}`, lang)}>
                  <h2 class="font-display text-2xl md:text-3xl font-bold text-base-content tracking-tight uppercase mb-3 hover:text-dark-600 transition-colors">{d.title}</h2>
                </a>
                <p class="text-body-xs mb-6">{d.location}</p>
                <p class="text-body mb-10">{d.description}</p>
                <div class="grid grid-cols-3 gap-6 mb-10 border-t border-base-300 pt-8">
                  <div>
                    <div class="font-display text-xl font-bold text-base-content tracking-tight">{d.totalUnits}</div>
                    <div class="text-meta mt-1">{t('projectDetail.totalUnits', lang)}</div>
                  </div>
                  <div>
                    <div class="font-display text-xl font-bold text-base-content tracking-tight">{d.area}</div>
                    <div class="text-meta mt-1">{t('projectsPage.area', lang)}</div>
                  </div>
                  <div>
                    <div class="font-display text-xl font-bold text-base-content tracking-tight">{d.year}</div>
                    <div class="text-meta mt-1">{t('projectsPage.year', lang)}</div>
                  </div>
                </div>
                <a href={localizedPath(`/projects/${slug}`, lang)} class="btn btn-outline">
                  {t('projectsPage.inquire', lang)}
                  <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  {page.cta && (
  <section class="relative bg-secondary text-secondary-content overflow-hidden">
    {/* {page.cta.image && (
    <div class="absolute inset-0">
      <img src={page.cta.image} alt={page.cta.heading} class="w-full h-full object-cover opacity-15" />
    </div>
    )} */}
    <div class="container section relative z-10">
      <div class="flex flex-col items-center gap-6">
        <h2 class="section-heading">{page.cta.heading}</h2>
        <p class="text-center max-w-md">{page.cta.description}</p>
        <a href={localizedPath(page.cta.primaryCta.href, lang)} class="btn btn-primary">
          {page.cta.primaryCta.label}
        </a>
      </div>
    </div>
  </section>
  )}
</BaseLayout>
