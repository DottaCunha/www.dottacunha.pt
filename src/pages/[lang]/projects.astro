---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, localizedPath, getI18nPaths } from '../../i18n/utils';
import type { Lang } from '../../i18n/translations';
import { getProjectsByLang, getProjectSlug, getStatusLabel } from '../../lib/projects';

export function getStaticPaths() { return getI18nPaths(); }

const { lang } = Astro.params as { lang: Lang };
const projects = await getProjectsByLang(lang);
---

<BaseLayout title={t('nav.projects', lang)} lang={lang}>
  <section class="pt-32 pb-16 px-6 md:px-8 bg-white">
    <div class="container-main">
      <span class="section-label">{t('projectsPage.label', lang)}</span>
      <h1 class="section-heading">{t('projectsPage.heading', lang)}</h1>
    </div>
  </section>

  <section class="pb-24 md:pb-32 px-6 md:px-8 bg-white">
    <div class="container-main">
      <div class="space-y-32">
        {projects.map((project, index) => {
          const d = project.data;
          const slug = getProjectSlug(project.id);
          const statusLabel = getStatusLabel(d.status, t, lang);
          return (
            <article class:list={[
              'grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start',
              index % 2 !== 0 ? 'lg:[direction:rtl]' : ''
            ]}>
              <a href={localizedPath(`/projects/${slug}`, lang)} class="lg:col-span-7 relative overflow-hidden aspect-[4/3] block group">
                <img src={d.image} alt={d.title} class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700" loading="lazy" />
                <div class="absolute top-5 left-5">
                  <span class:list={[
                    'badge',
                    d.status === 'completed' ? 'bg-dark-950 text-white' :
                    d.status === 'under_construction' ? 'bg-white text-dark-900' :
                    'bg-dark-100 text-dark-600'
                  ]}>
                    {statusLabel}
                  </span>
                </div>
              </a>
              <div class:list={['lg:col-span-5 py-4', index % 2 !== 0 ? 'lg:[direction:ltr]' : '']}>
                <div class="flex items-center gap-4 mb-5">
                  <span class="text-meta text-xxs">{d.type}</span>
                  <span class="text-dark-200">—</span>
                  <span class="text-footnote text-dark-300 font-light">{d.year}</span>
                </div>
                <a href={localizedPath(`/projects/${slug}`, lang)}>
                  <h2 class="font-display text-2xl md:text-3xl font-bold text-dark-950 tracking-tight uppercase mb-3 hover:text-dark-600 transition-colors">{d.title}</h2>
                </a>
                <p class="text-body-xs mb-6">{d.location}</p>
                <p class="text-body mb-10">{d.description}</p>
                <div class="grid grid-cols-3 gap-6 mb-10 border-t border-dark-100 pt-8">
                  <div>
                    <div class="font-display text-xl font-bold text-dark-900 tracking-tight">{d.totalUnits}</div>
                    <div class="text-meta mt-1">{t('projectDetail.totalUnits', lang)}</div>
                  </div>
                  <div>
                    <div class="font-display text-xl font-bold text-dark-900 tracking-tight">{d.area}</div>
                    <div class="text-meta mt-1">{t('projectsPage.area', lang)}</div>
                  </div>
                  <div>
                    <div class="font-display text-xl font-bold text-dark-900 tracking-tight">{d.year}</div>
                    <div class="text-meta mt-1">{t('projectsPage.year', lang)}</div>
                  </div>
                </div>
                <a href={localizedPath(`/projects/${slug}`, lang)} class="btn-outline">
                  {t('projectsPage.inquire', lang)}
                  <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section-padding bg-dark-950">
    <div class="container-main text-center">
      <h2 class="section-heading-light mb-5">{t('projectsPage.ctaHeading', lang)}</h2>
      <p class="text-body max-w-md mx-auto mb-10">{t('projectsPage.ctaDesc', lang)}</p>
      <a href={localizedPath('/contact', lang)} class="btn-primary !bg-white !text-dark-950 hover:!bg-dark-100">{t('cta.primary', lang)}</a>
    </div>
  </section>
</BaseLayout>
