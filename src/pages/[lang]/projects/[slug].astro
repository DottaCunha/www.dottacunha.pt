---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { t, localizedPath } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/translations';
import { getCollection } from 'astro:content';
import { getProjectSlug, getStatusLabel } from '../../../lib/projects';
import { supportedLangs } from '../../../i18n/translations';
import PublicPicture from '../../../components/PublicPicture.astro';

export async function getStaticPaths() {
  const allProjects = await getCollection('projects');
  const paths = [];

  for (const lang of supportedLangs) {
    const langProjects = allProjects.filter((p) => p.id.startsWith(`${lang}/`) && p.data.visible !== false);
    for (const project of langProjects) {
      const slug = getProjectSlug(project.id);
      paths.push({
        params: { lang, slug },
        props: { project },
      });
    }
  }

  return paths;
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const { project } = Astro.props;
const d = project.data;
const statusLabel = getStatusLabel(d.status, t, lang);
const units = d.units ?? [];
---

<BaseLayout title={d.title} darkHeader={true} lang={lang}>
  <!-- Hero -->
  <section class="relative min-h-[70vh] flex items-end bg-neutral text-primary-content overflow-hidden">
    <div class="absolute inset-0">
      <PublicPicture
        priority
        quality={60}
        sizes="100vw"
        src={d.image}
        formats={["avif", "webp"]}
        widths={[400, 800, 1200, 1600, 2400]}
        alt={d.title}
        class="w-full h-full object-cover opacity-50"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/30 to-primary/20"></div>
    </div>

    <div class="container relative z-10 px-6 md:px-8 pb-16 md:pb-24 pt-40">
      <a href={localizedPath('/projects', lang)} class="inline-flex items-center gap-2 text-link text-info hover:text-primary-content mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16l-4-4m0 0l4-4m-4 4h18"/></svg>
        {t('projectDetail.back', lang)}
      </a>

      <div class="flex items-center gap-4 mb-5">
        <span class:list={[
          'badge',
          d.status === 'completed' ? 'bg-base-100 text-base-content' :
          d.status === 'under_construction' ? 'bg-base-100 text-base-content' :
          'bg-base-300 text-dark-600'
        ]}>
          {statusLabel}
        </span>
        <span class="text-meta text-xxs">{d.type}</span>
      </div>

      <h1 class="heading-hero text-4xl md:text-6xl lg:text-7xl mb-4">
        {d.title}
      </h1>
      <p class="text-body">{d.location}</p>
    </div>
  </section>

  <!-- Project Info -->
  <section class="section bg-base-100">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-7">
          <p class="text-body text-secondary text-prose">{d.description}</p>
        </div>
        <div class="lg:col-span-5">
          <div class="grid grid-cols-2 gap-8 border-t border-base-300 pt-8">
            <div>
              <div class="font-display text-3xl font-bold text-base-content tracking-tight">{d.totalUnits}</div>
              <div class="text-meta mt-1">{t('projectDetail.totalUnits', lang)}</div>
            </div>
            <div>
              <div class="font-display text-3xl font-bold text-base-content tracking-tight">{d.area} m²</div>
              <div class="text-meta mt-1">{t('projectDetail.area', lang)}</div>
            </div>
            <div>
              <div class="font-display text-3xl font-bold text-base-content tracking-tight">{d.year}</div>
              <div class="text-meta mt-1">{t('projectsPage.year', lang)}</div>
            </div>
            <div>
              <div class="font-display text-lg font-bold text-base-content tracking-tight uppercase">{statusLabel}</div>
              <div class="text-meta mt-1">{t('projectDetail.status', lang)}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Units List -->
  {units.length > 0 && (
    <section class="pb-24 md:pb-32 px-6 md:px-8 bg-base-100">
      <div class="container">
        <div class="border-t border-base-300 pt-16">
          <span class="section-label">{t('projectDetail.units', lang)}</span>

          <div class="border-t border-base-300">
            {units.map((unit: any) => {
              const unitUrl = localizedPath(`/projects/${slug}/${unit.id}`, lang);
              const photo = unit.photos?.[0];
              return (
                <a href={unitUrl} class="group flex flex-col md:flex-row md:items-center gap-5 md:gap-8 py-6 md:py-5 border-b border-base-300 hover:bg-base-200/50 transition-colors md:px-4">
                  {/* Thumbnail */}
                  {photo && (
                    <div class="w-full md:w-44 md:h-28 flex-shrink-0 overflow-hidden">
                      <PublicPicture
                        src={photo}
                        alt={unit.typology}
                        formats={['avif', 'webp']}
                        widths={[400, 800, 1200, 1600]}
                        sizes="(max-width: 768px) 100vw, 176px"
                        loading="lazy"
                        class="w-full h-full object-cover aspect-[16/10] md:aspect-auto"
                      />
                    </div>
                  )}

                  {/* Info */}
                  <div class="flex-1 min-w-0">
                    <h3 class="heading-card-sm group-hover:text-dark-600 transition-colors">{unit.typology}</h3>
                    {unit.description && (
                      <p class="text-body-xs mt-1 line-clamp-1 hidden md:block">{unit.description}</p>
                    )}
                  </div>

                  {/* Specs */}
                  <div class="flex items-center gap-6 md:gap-8 flex-shrink-0">
                    <div class="text-center">
                      <div class="text-stat text-md">{unit.area} m²</div>
                      <div class="text-meta text-3xs mt-0.5">{t('projectDetail.area', lang)}</div>
                    </div>
                    <div class="text-center">
                      <div class="text-stat text-md">{unit.bedrooms}</div>
                      <div class="text-meta text-3xs mt-0.5">{t('unitDetail.bedrooms', lang)}</div>
                    </div>
                    <div class="text-center hidden sm:block">
                      <div class="text-stat text-md">{unit.floor}</div>
                      <div class="text-meta text-3xs mt-0.5">{t('unitDetail.floor', lang)}</div>
                    </div>
                    <svg class="w-5 h-5 text-dark-300 group-hover:text-base-content group-hover:translate-x-1 transition-all flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </div>
    </section>
  )}

  {units.length === 0 && (
    <section class="pb-24 md:pb-32 px-6 md:px-8 bg-base-100">
      <div class="container">
        <div class="border-t border-base-300 pt-16">
          <p class="text-body">{t('projectDetail.noUnits', lang)}</p>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section bg-secondary text-secondary-content">
    <div class="container text-center">
      <h2 class="section-heading mb-5">{t('projectsPage.ctaHeading', lang)}</h2>
      <p class="text-body max-w-md mx-auto mb-10">{t('projectsPage.ctaDesc', lang)}</p>
      <a href={localizedPath('/contact', lang)} class="btn btn-primary btn-inverted">
        {t('projectDetail.inquire', lang)}
      </a>
    </div>
  </section>
</BaseLayout>
