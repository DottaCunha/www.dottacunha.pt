---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, localizedPath, getI18nPaths } from '../../i18n/utils';
import type { Lang } from '../../i18n/translations';
import { getFeaturedProjectsByLang, getProjectSlug, getStatusLabel } from '../../lib/projects';

export function getStaticPaths() { return getI18nPaths(); }

const { lang } = Astro.params as { lang: Lang };
const featuredProjects = await getFeaturedProjectsByLang(lang);

const services = [
  { key: 'development', title: t('services.development', lang), description: t('services.development.desc', lang) },
  { key: 'architecture', title: t('services.architecture', lang), description: t('services.architecture.desc', lang) },
  { key: 'projectManagement', title: t('services.projectManagement', lang), description: t('services.projectManagement.desc', lang) },
  { key: 'investment', title: t('services.investment', lang), description: t('services.investment.desc', lang) },
];
---

<BaseLayout title={t('nav.home', lang)} darkHeader={true} lang={lang}>
  <!-- Hero -->
  <section class="section relative min-h-screen flex items-center bg-neutral text-neutral-content overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=1600&q=80"
        alt="Modern residential architecture"
        class="w-full h-full object-cover opacity-50"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/30 to-primary/50"></div>
    </div>

    <div class="container relative z-10">
      <div class="max-w-4xl">
        <p class="section-label mb-4">{t('hero.label', lang)}</p>
        <h1 class="heading-hero text-5xl md:text-7xl lg:text-display-lg mb-8">
          {t('hero.title', lang)}
        </h1>
        <p class="text-lg leading-relaxed mb-12 max-w-lg font-light">
          {t('hero.description', lang)}
        </p>
        <div class="flex items-center gap-6">
          <a href={localizedPath('/projects', lang)} class="btn btn-primary btn-inverted">
            {t('hero.cta', lang)}
          </a>
          <a href={localizedPath('/about', lang)} class="text-link hover:text-primary-content flex items-center gap-3">
            {t('hero.learn', lang)}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- About Teaser -->
  <section class="section bg-base-100 text-base-content">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        <div class="lg:col-span-5">
          <span class="section-label mb-3">{t('about.label', lang)}</span>
          <h2 class="section-heading mb-6">{t('about.heading', lang)}</h2>
          <div class="space-y-4 text-body">
            <p>{t('about.p1', lang)}</p>
            <p>{t('about.p2', lang)}</p>
          </div>
          <a href={localizedPath('/about', lang)} class="btn btn-outline mt-10">
            {t('about.cta', lang)}
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
        <div class="lg:col-span-7">
          <div class="grid grid-cols-2 gap-4">
            <div class="aspect-[3/4] overflow-hidden">
              <img src="https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=600&q=80" alt="Architecture detail" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="aspect-[3/4] overflow-hidden mt-12">
              <img src="https://images.unsplash.com/photo-1600573472592-401b489a3cdc?w=600&q=80" alt="Interior design" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="section bg-base-200 text-base-content">
    <div class="container">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
        <div>
          <span class="section-label mb-3">{t('projects.label', lang)}</span>
          <h2 class="section-heading">{t('projects.heading', lang)}</h2>
        </div>
        <a href={localizedPath('/projects', lang)} class="text-link text-info hover:text-base-content flex items-center gap-2">
          {t('projects.viewAll', lang)}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {featuredProjects.map(project => {
          const d = project.data;
          const slug = getProjectSlug(project.id);
          const statusLabel = getStatusLabel(d.status, t, lang);
          return (
            <a href={localizedPath(`/projects/${slug}`, lang)} class="group">
              <div class="relative overflow-hidden aspect-[3/4] mb-5">
                <img src={d.image} alt={d.title} class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="absolute top-4 left-4">
                  <span class="badge bg-primary text-primary-content">
                    {statusLabel}
                  </span>
                </div>
              </div>
              <div>
                <h3 class="heading-card-sm group-hover:text-dark-600 transition-colors">{d.title}</h3>
                <p class="text-body-xs mt-1">{d.location} — {d.totalUnits} {t('projects.units', lang)}</p>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="section bg-base-100 text-base-content">
    <div class="container">
      <div class="mb-16">
        <span class="section-label mb-3">{t('services.label', lang)}</span>
        <h2 class="section-heading mb-6">{t('services.heading', lang)}</h2>
        <p class="text-body max-w-lg">
          {t('services.description', lang)}
        </p>
      </div>

      <div class="border-t border-base-300" id="services-accordion">
        {services.map((service, index) => (
          <div class="border-b border-base-300" data-accordion-item>
            <button
              class="group w-full flex items-center justify-between py-8 text-left transition-all duration-300 hover:pl-4"
              data-accordion-trigger
              aria-expanded="false"
            >
              <div class="flex items-center gap-6">
                <span class="text-index">0{index + 1}</span>
                <h3 class="heading-card group-hover:text-secondary transition-colors">{service.title}</h3>
                <p class="text-body-sm max-w-lg">{service.description}</p>
              </div>
              <svg class="w-5 h-5 text-dark-300 group-hover:text-base-content transition-all duration-300 accordion-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 5v14m7-7H5"/></svg>
            </button>
            {/* <div class="accordion-content" data-accordion-content>
              <div class="pb-8 pl-0 md:pl-[3.25rem]">
                <a
                  href={`${localizedPath('/services', lang)}#${service.key}`}
                  class="inline-flex items-center gap-2 text-link text-base-content hover:text-secondary"
                >
                  {t('services.learnMore', lang)}
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
              </div>
            </div> */}
          </div>
        ))}
      </div>
    </div>
  </section>

  <style>
    .accordion-content {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 0.35s ease;
    }
    .accordion-content > div {
      overflow: hidden;
    }
    .accordion-content.is-open {
      grid-template-rows: 1fr;
    }
    .accordion-icon {
      transition: transform 0.35s ease, color 0.3s;
    }
    [aria-expanded="true"] .accordion-icon {
      transform: rotate(45deg);
    }
  </style>

  <script>
    const accordion = document.getElementById('services-accordion');
    if (accordion) {
      const triggers = accordion.querySelectorAll('[data-accordion-trigger]');
      triggers.forEach(trigger => {
        trigger.addEventListener('click', () => {
          const item = trigger.closest('[data-accordion-item]');
          const content = item?.querySelector('[data-accordion-content]');
          const isOpen = trigger.getAttribute('aria-expanded') === 'true';

          // Close all others
          triggers.forEach(other => {
            if (other !== trigger) {
              other.setAttribute('aria-expanded', 'false');
              other.closest('[data-accordion-item]')?.querySelector('[data-accordion-content]')?.classList.remove('is-open');
            }
          });

          // Toggle current
          trigger.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
          content?.classList.toggle('is-open', !isOpen);
        });
      });
    }
  </script>

  <!-- CTA Section -->
  <section class="relative bg-secondary text-secondary-content overflow-hidden">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=1600&q=80" alt="Architecture" class="w-full h-full object-cover opacity-15" />
    </div>
    <div class="container section relative z-10">
      <div class="max-w-2xl">
        <div class="flex flex-col gap-6">
          <span class="section-label">{t('cta.label', lang)}</span>
          <h2 class="section-heading">
            {t('cta.heading.1', lang)}<br />{t('cta.heading.2', lang)}
          </h2>
          <p class="max-w-md">
            {t('cta.description', lang)}
          </p>
        </div>
        <div class="flex flex-wrap gap-4 mt-10">
          <a href={localizedPath('/contact', lang)} class="btn btn-primary">
            {t('cta.primary', lang)}
          </a>
          <a href={localizedPath('/projects', lang)} class="btn btn-outline">
            {t('cta.secondary', lang)}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
