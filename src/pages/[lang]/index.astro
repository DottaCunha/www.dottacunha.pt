---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, localizedPath, getI18nPaths } from '../../i18n/utils';
import type { Lang } from '../../i18n/translations';
import { getFeaturedProjectsByLang, getProjectSlug, getStatusLabel } from '../../lib/projects';
import { getCollection } from 'astro:content';

export function getStaticPaths() { return getI18nPaths(); }

const { lang } = Astro.params as { lang: Lang };
const featuredProjects = await getFeaturedProjectsByLang(lang);

// Load homepage content for this language
const allPages = await getCollection('pages');
const homepage = allPages.find(p => p.id === `${lang}/homepage`);
if (!homepage) throw new Error(`Missing homepage content for language: ${lang}`);
const page = homepage.data;
const aboutParagraphs = page.about.body.split(/\n\s*\n/).map((p: string) => p.trim()).filter(Boolean);
---

<BaseLayout title={t('nav.home', lang)} darkHeader={true} lang={lang}>
  <!-- Hero -->
  <section class="section relative min-h-screen flex items-center bg-neutral text-neutral-content overflow-hidden">
    <div class="absolute inset-0">
      <img
        src={page.hero.image}
        alt="Modern residential architecture"
        class="w-full h-full object-cover opacity-50"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/30 to-primary/50"></div>
    </div>

    <div class="container relative z-10">
      <div class="max-w-4xl">
        <p class="section-label mb-4">{page.hero.label}</p>
        <h1 class="heading-hero text-5xl md:text-7xl lg:text-display-lg mb-8">
          {page.hero.title}
        </h1>
        <p class="text-lg leading-relaxed mb-12 max-w-lg font-light">
          {page.hero.description}
        </p>
        <div class="flex items-center gap-6">
          <a href={localizedPath(page.hero.cta.href, lang)} class="btn">
            {page.hero.cta.label}
          </a>
          <a href={localizedPath(page.hero.secondaryCta.href, lang)} class="btn btn-outline">
            {page.hero.secondaryCta.label}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- About Teaser -->
  <section class="section bg-base-100 text-base-content">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        <div class="lg:col-span-5">
          <span class="section-label mb-3">{page.about.label}</span>
          <h2 class="section-heading mb-6">{page.about.heading}</h2>
          <div class="space-y-4 text-body">
            {aboutParagraphs.map((p: string) => (
              <p>{p}</p>
            ))}
          </div>
          <a class="btn btn-outline mt-10" href={localizedPath(page.about.cta.href, lang)}>
            {page.about.cta.label}
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
        <div class="lg:col-span-7">
          <div class="grid grid-cols-2 gap-4">
            {page.about.images[0] && (
              <div class="aspect-[3/4] overflow-hidden">
                <img src={page.about.images[0]} alt="Architecture detail" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
              </div>
            )}
            {page.about.images[1] && (
              <div class="aspect-[3/4] overflow-hidden mt-12">
                <img src={page.about.images[1]} alt="Interior design" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <!-- <section class="section bg-base-200 text-base-content">
    <div class="container">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
        <div>
          <span class="section-label mb-3">{page.projects.label}</span>
          <h2 class="section-heading">{page.projects.heading}</h2>
        </div>
        <a href={localizedPath('/projects', lang)} class="text-link text-info hover:text-base-content flex items-center gap-2">
          {page.projects.viewAllLabel}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {featuredProjects.map(project => {
          const d = project.data;
          const slug = getProjectSlug(project.id);
          const statusLabel = getStatusLabel(d.status, t, lang);
          return (
            <a href={localizedPath(`/projects/${slug}`, lang)} class="group">
              <div class="relative overflow-hidden aspect-[3/4] mb-5">
                <img src={d.image} alt={d.title} class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="absolute top-4 left-4">
                  <span class="badge bg-primary text-primary-content">
                    {statusLabel}
                  </span>
                </div>
              </div>
              <div>
                <h3 class="heading-card-sm group-hover:text-dark-600 transition-colors">{d.title}</h3>
                <p class="text-body-xs mt-1">{d.location} — {d.totalUnits} {t('projects.units', lang)}</p>
              </div>
            </a>
          );
        })}
      </div>
      
    </div>
  </section> -->

  <!-- Services Overview -->
  <section class="section bg-base-200 text-base-content">
    <div class="container">
      <div class="mb-16">
        <span class="section-label mb-3">{page.services.label}</span>
        <h2 class="section-heading mb-6">{page.services.heading}</h2>
        <p class="text-body">
          {page.services.description}
        </p>
      </div>

      <div class="border-t border-base-300">
        {page.services.items.map((service: { key: string; title: string; description: string }, index: number) => (
          <div class="border-b border-base-300">
            <a
              href={`${localizedPath('/services', lang)}#${service.key}`}
              class="group w-full flex items-center justify-between py-8 text-left transition-all duration-300 hover:pl-4"
            >
              <div class="flex items-center gap-6">
                <span class="text-index">0{index + 1}</span>
                <h3 class="heading-card group-hover:text-secondary transition-colors">{service.title}</h3>
                <p class="text-body-sm max-w-lg">{service.description}</p>
              </div>
              <svg class="w-5 h-5 text-dark-300 group-hover:text-base-content transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="relative bg-secondary text-secondary-content overflow-hidden">
    <!-- <div class="absolute inset-0">
      <img src={page.cta.image} alt="Architecture" class="w-full h-full object-cover opacity-15" />
    </div> -->
    <div class="container section relative z-10">
      <div class="max-w-2xl">
        <div class="flex flex-col gap-6">
          <span class="section-label">{page.cta.label}</span>
          <h2 class="section-heading">
            {page.cta.heading}
          </h2>
          <p class="max-w-md">
            {page.cta.description}
          </p>
        </div>
        <div class="flex flex-wrap gap-4 mt-10">
          <a href={localizedPath(page.cta.primaryCta.href, lang)} class="btn btn-primary">
            {page.cta.primaryCta.label}
          </a>
          <a href={localizedPath(page.cta.secondaryCta.href, lang)} class="btn btn-outline">
            {page.cta.secondaryCta.label}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
