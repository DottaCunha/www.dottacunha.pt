---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, localizedPath, getI18nPaths } from '../../i18n/utils';
import type { Lang } from '../../i18n/translations';
import { getCollection } from 'astro:content';

export function getStaticPaths() { return getI18nPaths(); }

const { lang } = Astro.params as { lang: Lang };

const allPages = await getCollection('pages');
const servicesPage = allPages.find(p => p.id === `${lang}/services`);
const page = servicesPage!.data;
---

<BaseLayout title={t('nav.services', lang)} lang={lang} darkHeader>
  {page.hero && (
  <section class="section relative min-h-[40vh] flex items-end overflow-hidden bg-primary text-primary-content">
    <div class="absolute inset-0">
      <img src={page.hero.image} alt={page.hero.title} class="w-full h-full object-cover opacity-30" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/40 to-primary/60"></div>
    </div>
    <div class="container relative z-10">
      <span class="section-label mb-4">{page.hero.label}</span>
      <h1 class="heading-hero text-5xl md:text-7xl lg:text-display">{page.hero.title}</h1>
      {page.hero.description && <p class="max-w-xl mt-6">{page.hero.description}</p>}
    </div>
  </section>
  )}

  {page.serviceDetails && (
  <section class="section bg-base-100 text-base-content">
    <div class="container">
      <div class="border-t border-base-300">
        {page.serviceDetails.map((service, index) => (
          <div id={service.key} class="border-b border-base-300 py-10 md:py-14 scroll-mt-24">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
              <div class="lg:col-span-1">
                <span class="text-index">0{index + 1}</span>
              </div>
              <div class="lg:col-span-4">
                <h3 class="heading-card">{service.title}</h3>
              </div>
              <div class="lg:col-span-4">
                <p class="text-body-sm">{service.description}</p>
              </div>
              <div class="lg:col-span-3">
                <ul class="space-y-2">
                  {service.features.map(feature => (
                    <li class="flex items-center gap-3 text-body-xs text-secondary">
                      <span class="w-1 h-1 bg-dark-300 rounded-full shrink-0"></span>
                      {feature}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
  )}

  {page.process && (
  <section class="section bg-base-200">
    <div class="container">
      <div class="mb-20">
        <span class="section-label">{page.process.label}</span>
        <h2 class="section-heading">{page.process.heading}</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
        {page.process.items.map((item) => (
          <div>
            <div class="font-display text-6xl font-extrabold text-dark-100 tracking-tight mb-4">{item.step}</div>
            <h3 class="heading-card-sm text-base-content mb-3">{item.title}</h3>
            <p class="text-body-xs leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  )}

  {page.cta && (
  <section class="section bg-secondary text-secondary-content">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div>
          {page.cta.label && <span class="section-label !text-secondary">{page.cta.label}</span>}
          <h2 class="section-heading leading-[1] mb-6">{page.cta.heading}</h2>
          <p class="text-body mb-10 max-w-md">{page.cta.description}</p>
          {/* {page.cta.benefits && (
          <ul class="space-y-4">
            {page.cta.benefits.map(benefit => (
              <li class="flex items-center gap-3 text-body-xs text-dark-300">
                <span class="w-1.5 h-1.5 bg-primary-content rounded-full shrink-0"></span>
                {benefit}
              </li>
            ))}
          </ul>
          )} */}
        </div>
        {page.form && (
        <div class="bg-white/5 p-8 md:p-10 border border-white/10">
          <h3 class="heading-card-sm text-primary-content mb-8">{page.form.title}</h3>
          <form class="space-y-5 flex flex-col">
            <input type="text" placeholder={page.form.namePlaceholder} class="input input-dark w-full" />
            <input type="email" placeholder={page.form.emailPlaceholder} class="input input-dark w-full" />
            <select class="select input-dark text-info w-full">
              <option value="">{page.form.interestLabel}</option>
              {page.form.interests.map(interest => (
                <option value={interest.value}>{interest.label}</option>
              ))}
            </select>
            <textarea rows="3" placeholder={page.form.messagePlaceholder} class="textarea input-dark resize-none w-full"></textarea>
            <button type="submit" class="btn btn-primary btn-inverted w-full">{page.form.submitLabel}</button>
          </form>
        </div>
        )}
      </div>
    </div>
  </section>
  )}
</BaseLayout>
