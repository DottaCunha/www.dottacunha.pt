---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, localizedPath, getI18nPaths } from '../../i18n/utils';
import type { Lang } from '../../i18n/translations';

export function getStaticPaths() { return getI18nPaths(); }

const { lang } = Astro.params as { lang: Lang };

const values = [
  { title: t('aboutPage.value1.title', lang), description: t('aboutPage.value1.desc', lang) },
  { title: t('aboutPage.value2.title', lang), description: t('aboutPage.value2.desc', lang) },
  { title: t('aboutPage.value3.title', lang), description: t('aboutPage.value3.desc', lang) },
  { title: t('aboutPage.value4.title', lang), description: t('aboutPage.value4.desc', lang) },
];
---

<BaseLayout title={t('nav.about', lang)} darkHeader={true} lang={lang}>
  <!-- Hero -->
  <section class="section relative min-h-[40vh] flex items-end overflow-hidden bg-primary text-primary-content">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=1600&q=80" alt="Architecture" class="w-full h-full object-cover opacity-30" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/40 to-primary/60"></div>
    </div>
    <div class="container relative z-10">
      <span class="section-label mb-4">{t('aboutPage.label', lang)}</span>
      <h1 class="heading-hero text-5xl md:text-7xl lg:text-display">
        {t('aboutPage.heading', lang)}
      </h1>
    </div>
  </section>

  <!-- Story -->
  <section class="section bg-base-100 text-base-content">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24">
        <div class="lg:col-span-5">
          <span class="section-label mb-3">{t('aboutPage.whoLabel', lang)}</span>
          <h2 class="section-heading text-2xl md:text-4xl">{t('aboutPage.whoHeading', lang)}</h2>
        </div>
        <div class="lg:col-span-7 space-y-5 text-body leading-[1.8]">
          <p>{t('aboutPage.p1', lang)}</p>
          <p>{t('aboutPage.p2', lang)}</p>
          <p>{t('aboutPage.p3', lang)}</p>
          <p>{t('aboutPage.p4', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Image Break -->
  <section class="px-6 md:px-8">
    <div class="container">
      <div class="grid grid-cols-3 gap-4 h-[50vh]">
        <div class="overflow-hidden">
          <img src="https://images.unsplash.com/photo-1600573472592-401b489a3cdc?w=600&q=80" alt="Project detail" class="w-full h-full object-cover" />
        </div>
        <div class="overflow-hidden">
          <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=600&q=80" alt="Architecture" class="w-full h-full object-cover" />
        </div>
        <div class="overflow-hidden">
          <img src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=600&q=80" alt="Interior" class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section bg-base-100 text-base-content">
    <div class="container">
      <div class="mb-20">
        <span class="section-label mb-3">{t('aboutPage.valuesLabel', lang)}</span>
        <h2 class="section-heading">{t('aboutPage.valuesHeading', lang)}</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-base-300">
        {values.map((value, index) => (
          <div class="bg-base-100 p-10 md:p-14">
            <span class="text-index block mb-4">0{index + 1}</span>
            <h3 class="heading-card mb-4">{value.title}</h3>
            <p class="text-body-sm">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Numbers -->
  <section class="section bg-neutral text-neutral-content">
    <div class="container">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-12">
        <div>
          <div class="section-heading text-4xl md:text-5xl">2011</div>
          <div class="text-meta text-info mt-2">{t('aboutPage.numbersFounded', lang)}</div>
        </div>
        <div>
          <div class="section-heading text-4xl md:text-5xl">50+</div>
          <div class="text-meta text-info mt-2">{t('aboutPage.numbersProjects', lang)}</div>
        </div>
        <div>
          <div class="section-heading text-4xl md:text-5xl">500+</div>
          <div class="text-meta text-info mt-2">{t('aboutPage.numbersHomes', lang)}</div>
        </div>
        <div>
          <div class="section-heading text-4xl md:text-5xl">25+</div>
          <div class="text-meta text-info mt-2">{t('aboutPage.numbersTeam', lang)}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative bg-secondary text-secondary-content overflow-hidden">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=1600&q=80" alt="Architecture" class="w-full h-full object-cover opacity-15" />
    </div>
    <div class="container section relative z-10">
      <div class="flex flex-col items-center gap-6">
        <h2 class="section-heading">{t('aboutPage.ctaHeading', lang)}</h2>
        <p class="text-center max-w-md">{t('aboutPage.ctaDesc', lang)}</p>
        <a href={localizedPath('/contact', lang)} class="btn btn-primary">{t('cta.primary', lang)}</a>
      </div>
    </div>
  </section>
</BaseLayout>
