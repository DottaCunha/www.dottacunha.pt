---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, localizedPath, getI18nPaths } from '../../i18n/utils';
import type { Lang } from '../../i18n/translations';
import { getCollection } from 'astro:content';

export function getStaticPaths() { return getI18nPaths(); }

const { lang } = Astro.params as { lang: Lang };

// Load about page content for this language
const allPages = await getCollection('pages');
const aboutPage = allPages.find(p => p.id === `${lang}/about`);
if (!aboutPage) throw new Error(`Missing about page content for language: ${lang}`);
const page = aboutPage.data;

const storyParagraphs = page.story?.body.split(/\n\s*\n/).map((p: string) => p.trim()).filter(Boolean) ?? [];
---

<BaseLayout title={t('nav.about', lang)} darkHeader={true} lang={lang}>
  <!-- Hero -->
  <section class="section relative min-h-[40vh] flex items-end overflow-hidden bg-primary text-primary-content">
    <div class="absolute inset-0">
      <img src={page.hero?.image} alt="Architecture" class="w-full h-full object-cover opacity-30" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/40 to-primary/60"></div>
    </div>
    <div class="container relative z-10">
      <span class="section-label mb-4">{page.hero?.label}</span>
      <h1 class="heading-hero text-5xl md:text-7xl lg:text-display">
        {page.hero?.title}
      </h1>
    </div>
  </section>

  <!-- Story -->
  {page.story && (
    <section class="section bg-base-100 text-base-content">
      <div class="container">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24">
          <div class="lg:col-span-5">
            <span class="section-label mb-3">{page.story.label}</span>
            <h2 class="section-heading text-2xl md:text-4xl">{page.story.heading}</h2>
          </div>
          <div class="lg:col-span-7 space-y-5 text-body leading-[1.8]">
            {storyParagraphs.map((p: string) => (
              <p>{p}</p>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Image Break -->
  {page.images && page.images.length > 0 && (
    <section class="px-6 md:px-8">
      <div class="container">
        <div class="grid grid-cols-3 gap-4 h-[50vh]">
          {page.images.map((src: string, i: number) => (
            <div class="overflow-hidden">
              <img src={src} alt={`Image ${i + 1}`} class="w-full h-full object-cover" />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Values -->
  {page.values && (
    <section class="section bg-base-100 text-base-content">
      <div class="container">
        <div class="mb-20">
          <span class="section-label mb-3">{page.values.label}</span>
          <h2 class="section-heading">{page.values.heading}</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-base-300">
          {page.values.items.map((value: { title: string; description: string }, index: number) => (
            <div class="bg-base-100 p-10 md:p-14">
              <span class="text-index block mb-4">0{index + 1}</span>
              <h3 class="heading-card mb-4">{value.title}</h3>
              <p class="text-body-sm">{value.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  {page.cta && (
    <section class="relative bg-secondary text-secondary-content overflow-hidden">
      <div class="container section relative z-10">
        <div class="flex flex-col items-center gap-6">
          <h2 class="section-heading">{page.cta.heading}</h2>
          <p class="text-center max-w-md">{page.cta.description}</p>
          <a href={localizedPath(page.cta.primaryCta.href, lang)} class="btn btn-primary">{page.cta.primaryCta.label}</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>
