---
// Root page: detect browser language and redirect
// This runs at build time for SSG, so we use a client-side redirect
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dotta & Cunha — Redirecting...</title>
  <script is:inline>
    (function () {
      var supported = ['pt', 'en'];
      var defaultLang = 'pt';

      // Check stored preference first
      var stored = null;
      try { stored = localStorage.getItem('dc-lang'); } catch (e) {}

      if (stored && supported.indexOf(stored) !== -1) {
        window.location.replace('/' + stored);
        return;
      }

      // Detect browser language
      var browserLangs = navigator.languages || [navigator.language || ''];
      var detected = defaultLang;

      for (var i = 0; i < browserLangs.length; i++) {
        var code = browserLangs[i].split('-')[0].toLowerCase();
        if (supported.indexOf(code) !== -1) {
          detected = code;
          break;
        }
      }

      window.location.replace('/' + detected);
    })();
  </script>
  <!-- Fallback for no-JS -->
  <meta http-equiv="refresh" content="0;url=/pt" />
</head>
<body>
  <p style="font-family: system-ui; text-align: center; padding: 4rem;">Redirecting...</p>
</body>
</html>
